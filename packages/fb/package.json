{
	"name": "file-browser",
	"version": "2.0.0",
	"description": "A File Browser component for React - powered by HeroUI",
	"license": "MIT",
	"module": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"build:watch": "tsup --watch",
		"typecheck": "tsgo --noEmit",
		"lint": "oxlint -c oxlintrc.json",
		"lint:fix": "oxlint -c oxlintrc.json --fix",
		"prepublishOnly": "bun run build",
		"publish": "bun publish --access public --no-git-checks",
		"update": "bun update --latest"
	},
	"peerDependencies": {
		"@heroui/react": ">=3",
		"@heroui/styles": ">=3",
		"react": ">=18",
		"react-dom": ">=18"
	},
	"dependencies": {
		"@react-aria/focus": "^3.22.0",
		"@react-aria/i18n": "^3.13.0",
		"@react-aria/interactions": "^3.28.0",
		"@react-aria/utils": "^3.34.0",
		"@react-hook/media-query": "^1.1.1",
		"@reduxjs/toolkit": "^2.11.2",
		"clsx": "^2.1.1",
		"deepmerge": "^4.3.1",
		"exact-trie": "^1.0.13",
		"fast-sort": "^3.4.1",
		"filesize": "^11.0.17",
		"fuzzy-search": "^3.2.1",
		"immer": "11.1.8",
		"lodash.debounce": "^4.0.8",
		"react-redux": "^9.2.0",
		"redux-watch": "^1.2.0",
		"shortid": "^2.2.17",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tsdef": "^0.0.14"
	},
	"devDependencies": {
		"@heroui/react": "^3.0.4",
		"@heroui/styles": "^3.0.4",
		"@iconify/json": "^2.2.472",
		"@react-types/shared": "^3.34.0",
		"@svgr/core": "^8.1.0",
		"@svgr/plugin-jsx": "^8.1.0",
		"@types/fuzzy-search": "^2.1.5",
		"@types/lodash.debounce": "^4.0.9",
		"@types/memoizee": "^0.4.12",
		"@types/node": "^25.7.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-redux": "^7.1.34",
		"@types/redux-watch": "^1.1.2",
		"@types/shortid": "^2.2.0",
		"@typescript/native-preview": "^7.0.0-dev.20260513.1",
		"cross-env": "^10.1.0",
		"oxlint": "^1.64.0",
		"process": "^0.11.10",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-is": "^19.2.6",
		"rimraf": "^6.1.3",
		"size-limit": "^12.1.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"unplugin-icons": "^23.0.1"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/divyam234/tw-file-browser.git",
		"directory": "packages/fb"
	},
	"keywords": [
		"file",
		"file-dialog",
		"file-browser",
		"react-component"
	]
}
